# ============================================
# 开发环境 & 编辑器配置
# ============================================
.devcontainer/
.github/
.vscode/
.idea/
*.code-workspace

# ============================================
# Trae 自身配置（避免循环索引）
# ============================================
.trae/
!.trae/.ignore

# ============================================
# 二进制资源文件（图片、字体、图标）
# ============================================
assets/font/
assets/fonts/
assets/icons/
assets/img/
assets/images/
static/
resources/

# ============================================
# Hugo 构建产物（Token黑洞 #1）
# ============================================
public/
.hugo_build.lock
resources/_gen/

# ============================================
# 文章内容（Token黑洞 #2）
# 保留目录结构但忽略实际内容文件
# ============================================
content/**/*.md
content/**/*.html
content/**/*.mdx

# 如果你希望AI能看到content目录结构（但看不到内容），用下面这行：
# content/**/index.*

# 如果你希望AI完全看不到content目录：
# content/

# ============================================
# 依赖目录（Token黑洞 #3）
# ============================================
node_modules/
vendor/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# 日志 & 临时文件
# ============================================
*.log
.DS_Store
Thumbs.db
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# ============================================
# Git 相关
# ============================================
.git/
.gitattributes
.gitmodules
.gitkeep

# ============================================
# 其他大文件
# ============================================
*.zip
*.tar.gz
*.rar
*.7z
*.pdf
*.doc
*.docx
*.mp4
*.mp3
*.mov